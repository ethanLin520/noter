{
  "name": "noter",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-user meeting note-taking app with claude -p autocomplete, sanitize, and export",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/src/index.ts",
    "dev:client": "npm --prefix client run dev",
    "build": "npm run build:client",
    "build:client": "npm --prefix client run build",
    "start": "NODE_ENV=production tsx server/src/index.ts",
    "add-user": "tsx server/src/add-user.ts",
    "install:all": "npm install && npm --prefix client install"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "github-markdown-css": "^5.8.1",
    "md-to-pdf": "^5.2.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "allowScripts": {
    "esbuild@0.28.0": true
  }
}
